{
    "fullUrl":"urn:uuid:{{ ID }}",
    "resource":{
        "resourceType": "Device",
        "id":"{{ ID }}",
        "identifier":
        [
            {% assign ids = author.id | to_array -%}
            {% for id in ids -%}
                {% include 'DataType/Identifier', Identifier: id -%}
            {% endfor -%}
        ],
        {% assign manufacturerModelName = author.assignedAuthoringDevice.manufacturerModelName %}
        "manufacturer":"{{ manufacturerModelName._ | default: manufacturerModelName.displayName | escape_special_chars }}",
        "version":
        [
            {
                "value":"{{ author.assignedAuthoringDevice.softwareName._ }}",
            },
        ],
        "property": [
            {
                "type": {
                    "coding": [
                        {
                            "system": "http://hl7.org/fhir/device-category",
                            "code": "software",
                            "display": "software",
                        },
                    ]
                }
            }
        ],
    },
},
