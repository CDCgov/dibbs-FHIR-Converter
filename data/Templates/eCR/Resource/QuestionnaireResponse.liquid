{
    "fullUrl":"urn:uuid:{{ ID }}",
    "resource":{
        "resourceType": "QuestionnaireResponse",
        "id":"{{ ID }}",
        "status": "{{ entry.statusCode.code | get_property: 'ValueSet/QuestionnaireAnswerStatus' }}",
        "item": [
            {
                {% comment %} linkId is required for the FHIR bundle to be valid, it should point to 
                 a specific item in a Questionnaire but we don't always have Questionnaires. {% endcomment %}
                "linkId": "empty",

                {% if entry.code.displayName %}
                    "text": "{{  entry.code.displayName | escape_special_chars | clean_string_from_tabs }}",
                {% elsif entry.code.originalText.reference._ %}
                    "text": "{{  entry.code.originalText.reference._ | escape_special_chars | clean_string_from_tabs }}",
                {% elsif entry.code.originalText._ %}
                    "text": "{{  entry.code.originalText._ | escape_special_chars | clean_string_from_tabs }}",
                {% endif %}
                
                {% comment %} answers can't be any valueX they have to be 
                single-valued valueX see https://hl7.org/fhir/R4/questionnaireresponse.html {% endcomment %}
                "answer": [
                    {% assign entryValues = entry.value | to_array %}
                    {% for entryValue in entryValues %}
                        {% if entryValue.translation %}
                            {% assign translations = entryValue.translation | to_array -%}
                            {% for translation in translations %}
                                {
                                    "valueCoding": { {% include 'DataType/Coding', Coding: translation %} }
                                },
                            {% endfor %}
                        {% else %}
                            {
                                {% include 'Utils/ValueHelper', value: entryValue, singleValued: true %}
                            },
                        {% endif %}
                    {% endfor %}
                ]
            }
        ]
    },
},